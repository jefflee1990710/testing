# ==============================================================================
# VC4S STARTER TEMPLATE ENVIRONMENT CONFIGURATION (EXAMPLE)
# Copy this file to .env and fill in your actual values.
# ==============================================================================

# Node Environment
NODE_ENV=development

# Server Port
PORT=3000

# ------------------------------------------------------------------------------
# MONGODB CONFIGURATION
# ------------------------------------------------------------------------------
MONGODB_URI=mongodb://localhost:27017/vc4s
MONGODB_DB=vc4s

# ------------------------------------------------------------------------------
# JWT AUTHENTICATION
# ------------------------------------------------------------------------------
JWT_SECRET=your-super-secret-user-jwt-key
JWT_ADMIN_SECRET=your-super-secret-admin-jwt-key

# ------------------------------------------------------------------------------
# EMAIL (SMTP) CONFIGURATION
# ------------------------------------------------------------------------------
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=user@example.com
SMTP_PASS=password
SMTP_FROM="VC4S Starter Template" <noreply@example.com>
DEFAULT_ADMIN=true
